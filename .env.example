# --- Database (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=relayx
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Authentication (JWT) ---
# Use long, random strings for keys in production!
JWT_SECRET_KEY=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-long-random-refresh-secret
SECRET_EXPIRY=15m
REFRESH_EXPIRY=7d

# --- CORS ---
# Local frontend origin: http://localhost:5173
CORS_ORIGINS=["http://localhost:5173"]

# --- API URLs (Frontend) ---
VITE_AUTH_API_URL=http://localhost:8000
VITE_CHAT_API_URL=http://localhost:8001
VITE_CHAT_WS_URL=ws://localhost:8001/ws
